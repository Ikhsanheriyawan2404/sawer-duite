### Variables
@baseUrl = http://localhost:3000

# Auto-populated after running login
@accessToken = {{login.response.body.access_token}}
@refreshToken = {{login.response.body.refresh_token}}
@appToken = {{login.response.body.user.app_token}}


###########################################################
### SYSTEM & HEALTH
###########################################################

### Health Check
GET {{baseUrl}}/health

###########################################################
### AUTHENTICATION
###########################################################

### Login
# @name login
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "admin@gmail.com",
  "password": "anone"
}

### Refresh Token
POST {{baseUrl}}/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Get Current User Profile (Authenticated)
GET {{baseUrl}}/me
Authorization: Bearer {{accessToken}}

### Update Basic Profile (Authenticated)
POST {{baseUrl}}/me/profile
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Ikhsan Heriyawan",
  "username": "ikhsan",
  "bio": "Streaming setiap malam Jumat",
  "social_links": {
    "tiktok": "https://tiktok.com/@ikhsan",
    "instagram": "https://instagram.com/ikhsan",
    "youtube": "https://youtube.com/@ikhsan"
  }
}

###########################################################
### PUBLIC USER DATA
###########################################################

### Get Public User by Username
GET {{baseUrl}}/user/ikhsan

### Get Public User by UUID
GET {{baseUrl}}/user/uuid/f9d34e24-58c5-441f-bdeb-bcfd0d987e6b

### List Public Users
GET {{baseUrl}}/users?limit=10

###########################################################
### TRANSACTIONS & DONATIONS
###########################################################

### Create Transaction (Donation)
# @name createTransaction
POST {{baseUrl}}/transactions
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "username": "ikhsan",
  "amount": 50000,
  "sender": "Donatur Budiman",
  "note": "Semangat bang streamingnya!",
  "custom_input_json": {
    "field_1775725636667": "brogrammer99"
  },
  "media_url": "https://youtube.com/watch?v=dQw4w9WgXcQ",
  "supporter_id": "guest-uuid-local"
}

### Get Transaction Details
GET {{baseUrl}}/transactions/{{createTransaction.response.body.uuid}}

### Get User Donation Stats (Landing Page)
GET {{baseUrl}}/user/ikhsan/stats

### Get Queue List (Overlay)
GET {{baseUrl}}/user/ikhsan/queue?status=PAID&is_queue=true&order=desc

###########################################################
### NOTIFICATIONS & LOGS (From Android App)
###########################################################

### Process Payment Notification (Mock Dana/GoPay)
POST {{baseUrl}}/notifications
X-App-Token: {{appToken}}
Content-Type: application/json

{
  "title": "GOPAY",
  "message": "Pembayaran QRIS Rp 100063 di IKHSAN HERIYAWAN, Digital & Kreatif telah diterima.",
  "amount": 100063,
  "bank": "GOPAY",
  "source": "NotificationListener"
}

### Upload Client Logs
POST {{baseUrl}}/client-logs
X-App-Token: {{appToken}}
Content-Type: application/json

[
  {
    "ts": 1712419200000,
    "level": "INFO",
    "event": "NOTIFICATION_CAPTURED",
    "message": "Captured notification from DANA",
    "device": {"model": "Pixel 6", "os": "Android 14"}
  }
]

###########################################################
### OVERLAY & QUEUE MANAGEMENT (Authenticated)
###########################################################

### Trigger Test Alert
POST {{baseUrl}}/user/{{login.response.body.user.uuid}}/test-alert
Authorization: Bearer {{accessToken}}

###########################################################
### OVERLAY SETTINGS (Authenticated)
###########################################################

### Update Alert Config
POST {{baseUrl}}/me/alert-config
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Update Queue Config (Title Only)
POST {{baseUrl}}/me/queue-config
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "queue_title": "Antrian Donasi"
}

### Update List Overlay Config
POST {{baseUrl}}/me/list-config
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Daftar Donatur",
  "starts_at": "2026-01-01T00:00:00+07:00",
  "ends_at": "2026-12-31T23:59:59+07:00"
}

### Update Media Overlay Config
POST {{baseUrl}}/me/media-config
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "enabled": true
}

### Update Donation Packages (Bulk)
POST {{baseUrl}}/me/donation-packages
Authorization: Bearer {{accessToken}}
Content-Type: application/json

[
  { "label": "Request Lagu", "amount": 25000 },
  { "label": "Review Akun", "amount": 50000 }
]

### Update Payment Settings
POST {{baseUrl}}/me/payment
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "provider": "DANA",
  "static_qris": "PASTEKAN_QRIS_DISINI"
}

### Update Custom Input Schema
POST {{baseUrl}}/me/config
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "custom_input_schema": [
    { "key": "username_game", "label": "Username Game", "required": true }
  ]
}

### Goals - List
GET {{baseUrl}}/me/goals
Authorization: Bearer {{accessToken}}

### Goals - Create
POST {{baseUrl}}/me/goals
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Beli Microphone",
  "target_amount": 3000000,
  "is_active": true
}

### Goals - Update
PATCH {{baseUrl}}/me/goals/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Beli Microphone Pro",
  "target_amount": 3500000
}

### Goals - Activate
POST {{baseUrl}}/me/goals/1/activate
Authorization: Bearer {{accessToken}}

### Goals - Delete
DELETE {{baseUrl}}/me/goals/1
Authorization: Bearer {{accessToken}}

### Update Queue Status for Transaction
PATCH {{baseUrl}}/transactions/{{createTransaction.response.body.uuid}}/queue
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "is_queue": false
}

### Add Transaction Back to Queue
POST {{baseUrl}}/transactions/{{createTransaction.response.body.uuid}}/queue/add
Authorization: Bearer {{accessToken}}

### Remove Transaction from Queue
POST {{baseUrl}}/transactions/{{createTransaction.response.body.uuid}}/queue/remove
Authorization: Bearer {{accessToken}}
